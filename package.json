{
  "name": "@bg-effects/boids",
  "version": "1.0.3",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "description": "Boids Background Effect - A high-performance boids simulation background effect built with OGL and Vue.",
  "author": "huangzida",
  "license": "MIT",
  "keywords": [
    "boids",
    "webgl",
    "ogl",
    "vue",
    "background-effect",
    "animation"
  ],
  "homepage": "https://github.com/huangzida/boids#readme",
  "bugs": {
    "url": "https://github.com/huangzida/boids/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huangzida/boids.git"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=20.17.0"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "scripts": {
    "dev": "pnpm play",
    "dev:watch": "vite build --watch",
    "play": "vite --mode playground",
    "build": "vite build",
    "build:play": "vite build --mode playground",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "format": "prettier --write \"**/*.{ts,vue,md,json}\"",
    "release": "plop --plopfile scripts/release.cjs",
    "clear": "rm -rf dist",
    "no-lockfile": "pnpm install --no-frozen-lockfile",
    "reinstall": "npx rimraf node_modules **/node_modules pnpm-lock.yaml && pnpm install"
  },
  "dependencies": {
    "@bg-effects/debug-ui": "catalog:",
    "defu": "^6.1.4"
  },
  "devDependencies": {
    "@bg-effects/configs": "catalog:",
    "@bg-effects/core": "catalog:",
    "@bg-effects/shared": "catalog:",
    "@eslint/js": "^9.21.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "changelogen": "^0.6.2",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "ogl": "^1.0.11",
    "plop": "^4.0.1",
    "prettier": "^3.5.1",
    "simple-git": "^3.32.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "unocss": "^65.4.3",
    "vite": "^6.1.1",
    "vite-plugin-css-injected-by-js": "^3.5.0",
    "vite-plugin-dts": "^4.5.1",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  },
  "peerDependencies": {
    "ogl": "^1.0.0",
    "vue": "^3.3.0"
  }
}
